ISS_API_BASE_URL=http://localhost:5257
# Optional: set false when running over plain HTTP (for example, a raw server IP without TLS)
# ISS_SECURE_COOKIES=false
# Optional: backend proxy upstream timeout in milliseconds (default 30000)
# ISS_BACKEND_PROXY_TIMEOUT_MS=30000
# Optional: set true to expose self-registration in the login UI (default is enabled in dev, disabled in production)
# NEXT_PUBLIC_ISS_ALLOW_SELF_REGISTRATION=true
